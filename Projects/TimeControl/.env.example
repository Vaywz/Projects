# HitexisTimeControl Environment Variables

# ============================================
# Application Settings
# ============================================
APP_NAME=HitexisTimeControl
DEBUG=false

# ============================================
# Security & JWT
# ============================================
# Secret key for JWT tokens (REQUIRED - change in production!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Database Configuration
# ============================================
# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-database-password
POSTGRES_DB=hitexis_time
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URLs are optional. Leave blank to build them from POSTGRES_* values.
DATABASE_URL=
DATABASE_URL_SYNC=

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# Celery Configuration
# ============================================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================
# Microsoft Graph Settings for email notifications
# ============================================
# App requires Microsoft Graph application permission: Mail.Send
MS_TENANT_ID=your-directory-tenant-id
MS_CLIENT_ID=your-application-client-id
MS_CLIENT_SECRET=your-client-secret-value
MS_FROM_EMAIL=no-reply@example.com
MS_FROM_NAME=HitexisTimeControl

# CORS origins allowed by backend, comma-separated
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=/api

# ============================================
# File Storage
# ============================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880
